<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#F4F0E8"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".About">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1C2B1A"
        android:id="@+id/header1"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!--        TextView-->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📜 About Us"
            android:textSize="40sp"
            android:textAlignment="center"
            android:textStyle="bold|italic"
            android:textColor="#E8D5A3"
            android:letterSpacing="0.02"
            android:fontFamily="serif"/>

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="20dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/aboutTxt"
                android:text="Our e-commerce application provides a fast, secure, and seamless shopping experience designed for all users. You can easily browse a wide variety of products, compare different options, and enjoy exclusive discounts and special offers. Payments are safely and conveniently processed through M-Pesa, ensuring both reliability and trust. The platform also features real-time order tracking, smooth checkout, and efficient customer support. With quick doorstep delivery and an intuitive, user-friendly interface, shopping becomes convenient, efficient, and accessible anytime and anywhere. We are committed to improving your experience and making online shopping simple, enjoyable, and stress-free. Thank you for choosing Sokogarden."
                android:textSize="15sp"
                android:textColor="#7A9B72"
                android:fontFamily="serif"/>

            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:id="@+id/btnListen"
                android:text="🔊  Know Us"
                android:backgroundTint="#2E4A2C"
                android:textColor="#E8D5A3"
                android:fontFamily="sans-serif-black"
                android:padding="12dp"
                android:textSize="20sp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>