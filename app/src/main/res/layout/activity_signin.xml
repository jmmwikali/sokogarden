<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#FFE6C8"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Signin">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="❇  Sign In ❇"
        android:textSize="40sp"
        android:textStyle="bold|italic"
        android:background="@drawable/shape"
        android:padding="12sp"
        android:textColor="#fff"
        android:textAlignment="center"/>

<!--    Below is a cardView-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        android:layout_margin="15dp"
        app:cardElevation="10dp">

<!--        Below is a linear layout that will align content vertically-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="#fff">

<!--            Below is the email EditText-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="✉️  Enter Email Address"
                android:textColorHint="#000"
                android:id="@+id/email"
                android:textColor="#000"
                android:textSize="20sp"
                android:layout_margin="8sp"
                android:backgroundTint="#000"
                android:padding="11dp"/>

 <!--            Below is the password EditText-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="🔑  Enter Password"
                android:textColorHint="#000"
                android:id="@+id/password"
                android:textColor="#000"
                android:textSize="20sp"
                android:layout_margin="8sp"
                android:backgroundTint="#000"
                android:padding="11dp"/>

<!--            Below is the signIn button-->
            <Button
                android:layout_width="match_parent"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="SignIn"
                android:textSize="30sp"
                android:padding="10dp"
                android:layout_marginStart="55dp"
                android:layout_marginEnd="55dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="#F48902"
                android:textColor="#fff"
                android:id="@+id/signinbtn"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signup_text"
                android:textAlignment="center"
                android:fontFamily="sans-serif-light"
                android:textSize="20sp"
                android:id="@+id/signuptxt"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:textColor="#0075FF"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>