<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F0E8">

    <!-- Logo -->
    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛒 SokoGarden"
        android:textSize="42sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="#E8D5A3"
        android:letterSpacing="0.04"
        android:shadowColor="#1C2B1A"
        android:shadowDx="0"
        android:shadowDy="2"
        android:shadowRadius="10"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp" />

    <!-- Gold divider line -->
    <View
        android:id="@+id/divider"
        android:layout_width="72dp"
        android:layout_height="1.5dp"
        android:background="@drawable/divider_gold"
        app:layout_constraintTop_toBottomOf="@id/tvLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EVERYTHING YOU NEED"
        android:textSize="11sp"
        android:fontFamily="serif"
        android:textStyle="italic"
        android:textColor="#7A9B72"
        android:letterSpacing="0.22"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp" />

    <!-- Bottom dark green panel -->
    <View
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bottom_panel"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Brand name inside panel -->
    <TextView
        android:id="@+id/tvBrand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SOKOGARDEN"
        android:textSize="9sp"
        android:fontFamily="serif"
        android:textColor="#E8D5A3"
        android:letterSpacing="0.38"
        android:alpha="0.55"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- Loading dots -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@id/tvBrand"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp">

        <View
            android:id="@+id/dot1"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/dot_gold" />

        <View
            android:id="@+id/dot2"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/dot_gold" />

        <View
            android:id="@+id/dot3"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/dot_gold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>