<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

<!--    Below is a card view-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="16dp"
        android:layout_margin="10dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF">

<!--        Below is another linear layout that dictates how the contents will be aligned-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/product_name"
                android:text="Product Name"
                android:textStyle="bold"
                android:textSize="25sp"
                android:fontFamily="serif"
                android:textAlignment="center"
                android:textColor="#C47B2A"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3sp"
                app:cardCornerRadius="16dp">

<!--            Below is out product image-->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:id="@+id/product_photo"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop" />

            </androidx.cardview.widget.CardView>


<!--            Below is a text view for the product cost-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/product_cost"
                android:text="KES 500"
                android:textColor="#1C2B1A"
                android:layout_marginTop="10sp"
                android:textStyle="bold"
                android:textSize="25dp"
                android:background="@drawable/shape"
                android:padding="10dp"/>

<!--            Below is a text view for the product description-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/product_description"
                android:text="The product's description will appear here."
                android:textColor="#7A9B72"
                android:textSize="18dp"
                android:layout_marginTop="3dp"
                android:textStyle="italic"/>

<!--            Below is the purchase now button-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/btnPurchase"
                android:layout_marginTop="5dp"
                android:text="Purchase Now"
                android:fontFamily="sans-serif-black"
                android:padding="12dp"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C47B2A"/>



        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>