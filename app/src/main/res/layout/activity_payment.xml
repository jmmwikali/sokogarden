<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#F4F0E8"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PaymentActivity">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1C2B1A"
        android:id="@+id/header1"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

<!--        TextView-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Complete Your Order With M-Pesa"
            android:textSize="30sp"
            android:textAlignment="center"
            android:textStyle="bold|italic"
            android:textColor="#E8D5A3"
            android:letterSpacing="0.02"
            android:fontFamily="serif"/>

    </LinearLayout>

<!--    CardView holding all the content-->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        android:layout_margin="20dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FFFFFF">

<!--        LinearLayout-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

<!--            TextView for binding the product_name-->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductName"
                android:text="Product Name"
                android:textStyle="bold"
                android:textSize="26sp"
                android:fontFamily="serif"
                android:textAlignment="center"
                android:textColor="#C47B2A"/>

<!--            ImageView for the product_photo-->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3sp"
                app:cardCornerRadius="16dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:id="@+id/imgProduct"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop" />

            </androidx.cardview.widget.CardView>

<!--            TextView for product_cost-->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/txtProductCost"
                android:text="Ksh 1000"
                android:textColor="#1C2B1A"
                android:layout_marginTop="10sp"
                android:textStyle="bold"
                android:textSize="25dp"
                android:background="@drawable/shape"
                android:padding="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter Your Phone Number"
                android:textSize="18sp"
                android:textColor="#7A9B72"
                android:layout_marginTop="14dp"/>

<!--            EditText for entering mobile number-->
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/phone"
                android:hint="25479730..."
                android:textColorHint="#A89E86"
                android:background="@drawable/shape"
                android:layout_marginTop="2dp"
                android:padding="14dp"
                android:inputType="number"
                android:textColor="#1C2B1A"
                android:textSize="17sp"/>

<!--            Button for payment completion-->
            <Button
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/pay"
                android:text="Pay Now"
                android:layout_marginTop="7dp"
                android:fontFamily="sans-serif-black"
                android:padding="12dp"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C47B2A"/>


        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>