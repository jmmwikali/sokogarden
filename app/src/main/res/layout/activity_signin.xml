<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#F4F0E8"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Signin">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1C2B1A"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="28dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✨ Sign In"
            android:textSize="36sp"
            android:textStyle="bold|italic"
            android:textColor="#E8D5A3"
            android:letterSpacing="0.02"
            android:fontFamily="serif"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WELCOME BACK"
            android:textSize="12sp"
            android:letterSpacing="0.2"
            android:textColor="#7A9B72"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Form Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        android:layout_margin="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR ACCOUNT"
                android:textSize="12sp"
                android:letterSpacing="0.15"
                android:textColor="#7A9B72"
                android:layout_marginBottom="14dp"/>

            <!-- Email -->
            <EditText
                android:id="@+id/email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Email address"
                android:textColorHint="#A89E86"
                android:textColor="#1C2B1A"
                android:textSize="17sp"
                android:background="@drawable/shape"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="12dp"/>

            <!-- Password -->
            <EditText
                android:id="@+id/password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Password"
                android:textColorHint="#A89E86"
                android:textColor="#1C2B1A"
                android:textSize="17sp"
                android:background="@drawable/shape"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:inputType="textPassword"
                android:layout_marginBottom="20dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E8E0D0"
                android:layout_marginBottom="20dp"/>

            <!-- Sign In Button -->
            <Button
                android:id="@+id/signinbtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign In"
                android:padding="12dp"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#C47B2A"
                android:layout_marginBottom="16dp"/>

            <!-- Sign Up link -->
            <TextView
                android:id="@+id/signuptxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/signup_text"
                android:textAlignment="center"
                android:textSize="15sp"
                android:textColor="#7A9B72"
                android:layout_marginBottom="4dp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>